<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <!-- Create Room -->
    <Button
        android:id="@+id/btnCreateRoom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Create Room"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvCreateResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create result will appear here"
        android:textStyle="bold"
        android:textSize="16sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnCreateRoom"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Enter Room Code -->
    <EditText
        android:id="@+id/etRoomCode"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Enter Room Code"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvCreateResult"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnLookupRoom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Join Room"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/etRoomCode"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvLookupResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lookup result here"
        android:textSize="16sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnLookupRoom"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Loader -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvLookupResult"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>